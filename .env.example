# ── AgriSetu Environment Variables ─────────────────────────
# Copy this to .env and fill in your values

FLASK_ENV=development
PORT=5000
BASE_URL=http://localhost:5000
SECRET_KEY=change-me-in-production

# ThingESP (your IoT sensor platform)
THINGESP_USERNAME=Noctum
THINGESP_PROJECT=Agrisetu
THINGESP_TOKEN=your_thingesp_token_here

LOG_LEVEL=INFO
